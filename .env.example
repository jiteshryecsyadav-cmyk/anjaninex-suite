# ============================================
# Namokara Suite — Environment Template
# Copy to .env and fill values for local dev
# ============================================

# Database
POSTGRES_USER=namokara
POSTGRES_PASSWORD=dev_only_change_me
POSTGRES_DB=namokara_dev
POSTGRES_PORT=5432
PGBOUNCER_PORT=6432

# Redis
REDIS_PASSWORD=dev_only_change_me
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=namokara
MINIO_ROOT_PASSWORD=dev_only_change_me
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Seq (log viewer)
SEQ_PORT=5341

# PgAdmin
PGADMIN_EMAIL=dev@namokara.local
PGADMIN_PASSWORD=dev_only_change_me
PGADMIN_PORT=5050

# Mailhog (email catcher)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# API
API_PORT=5000
JWT_SECRET=please-change-this-to-a-long-random-string-at-least-32-chars
JWT_ISSUER=namokara.local
JWT_AUDIENCE=namokara-suite

# Frontend
WEB_PORT=4200
ADMIN_PORT=4201

# AI (leave blank for mock mode in dev)
AI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# WhatsApp (Phase 2)
WA_ENABLED=false
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_VERIFY_TOKEN=

# SMS (Phase 2)
SMS_ENABLED=false
MSG91_AUTH_KEY=

# Email
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@namokara.local

# Anjaninex branding
ANJANINEX_LOGO_URL=/assets/anjaninex-logo.png
ANJANINEX_SUPPORT_EMAIL=support@anjaninex.com
ANJANINEX_ADMIN_URL=http://localhost:4201

# Observability
JAEGER_PORT=16686
OTLP_HTTP_PORT=4318
