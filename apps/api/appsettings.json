{
  "ConnectionStrings": {
    "_comment": "Production: use namokara_app role (RLS-enforced). Set via env var NAMOKARA_DB_PASSWORD.",
    "Postgres": "Host=localhost;Port=6432;Database=namokara_prod;Username=namokara_app;Password=${NAMOKARA_DB_PASSWORD}"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=${NAMOKARA_REDIS_PASSWORD}",
    "InstanceName": "namokara:"
  },
  "Jwt": {
    "Issuer": "namokara.production",
    "Audience": "namokara-suite",
    "_comment": "Key MUST be set via NAMOKARA_JWT_KEY env var (min 64 bytes). App fails startup if missing or matches dev pattern.",
    "Key": "${NAMOKARA_JWT_KEY}",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Cors": {
    "_comment": "Production origins only. Localhost in appsettings.Development.json.",
    "Origins": [
      "https://app.namokara.com",
      "https://admin.anjaninex.com"
    ]
  },
  "Storage": {
    "Provider": "MinIO",
    "Endpoint": "${NAMOKARA_MINIO_ENDPOINT}",
    "AccessKey": "${NAMOKARA_MINIO_ACCESS_KEY}",
    "SecretKey": "${NAMOKARA_MINIO_SECRET_KEY}",
    "UseSsl": true,
    "BucketBills": "namokara-bills",
    "BucketPhotos": "namokara-photos",
    "BucketSelfies": "namokara-selfies",
    "BucketDocs": "namokara-docs",
    "PresignedUrlExpiryMinutes": 15
  },
  "AI": {
    "Enabled": false,
    "GeminiApiKey": "",
    "GeminiModel": "gemini-2.5-flash",
    "EnableMockResponses": true
  },
  "WhatsApp": { "Enabled": false },
  "Sms": { "Enabled": false },
  "Versioning": {
    "ApiVersion": "1.0.0",
    "MinClientVersion": "1.0.0",
    "ForceUpdateOnMismatch": false
  },
  "Anjaninex": {
    "AdminPortalUrl": "http://localhost:4201",
    "SupportEmail": "support@anjaninex.com",
    "SupportPhone": "+91-9876543210",
    "BillingEmail": "billing@anjaninex.com"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "AllowedHosts": "app.namokara.com;admin.anjaninex.com"
}
