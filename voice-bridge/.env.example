# Sarvam + Gemini Exotel voice bridge — config
# Copy to .env aur apni keys bharo (chat me kabhi paste mat karna).

SARVAM_API_KEY=your_sarvam_api_subscription_key
GEMINI_API_KEY=your_gemini_api_key

# Database — per-firm agent config yahin se load hoti hai (platform.voice_agents).
# Isi namokara DB se connect karo (read-only kaafi hai).
DATABASE_URL=postgresql://namokara_app:YOUR_DB_PASSWORD@localhost:5432/namokara

PORT=10002

# Bhasha aur awaaz
LANGUAGE=hi-IN
TTS_SPEAKER=anushka
TTS_MODEL=bulbul:v2
STT_MODEL=saarika:v2.5
GEMINI_MODEL=gemini-2.0-flash

# Agent kya bole (call uthate hi)
FIRST_MESSAGE=Namaste! Main Riddhi bol rahi hoon, Anjaninex se. Aapki kya madad kar sakti hoon?

# Agent ka behaviour (single line me; \n mat daalo)
SYSTEM_PROMPT=Tum 'Riddhi' ho, Anjaninex ki friendly hindi phone assistant. Chhote saral vaakya me garmjoshi se baat karo. Ek baar me ek sawaal. Jo nahi pata saaf bolo ki main confirm karke bata deti hoon. Jhoothi jaankari mat do.

# Turn detection (agar anji jaldi kaat de to SILENCE_MS badhao; shor me VAD_THRESHOLD badhao)
SILENCE_MS=700
VAD_THRESHOLD=500
MIN_SPEECH_MS=300
